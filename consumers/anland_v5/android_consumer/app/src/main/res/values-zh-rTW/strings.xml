    <!-- Accessibility -->
    <string name="accessibility_switch">無障礙按鍵攔截</string>
    <string name="accessibility_hint">透過無障礙服務攔截功能鍵（Fn、F1-F12 等）。如果外接鍵盤的 Fn 組合鍵無法傳到桌面，請啟用此項。需要在系統 設定 &gt; 無障礙 中授予無障礙權限（僅需一次）。</string>

    <!-- Extra keys bar -->
    <string name="extra_keys_mode_label">擴充按鍵列模式</string>
    <string name="extra_keys_mode_hint">控制何時顯示類似 Termux 的底部按鍵列（含 ESC/TAB/CTRL/ALT/方向鍵/PgUp 等）。下次返回桌面檢視時生效。</string>
    <string-array name="extra_keys_mode_options">
        <item>始終顯示</item>
        <item>不顯示</item>
        <item>隨軟鍵盤顯示</item>
    </string-array>
    <string name="back_opens_switch">返回鍵快速切換擴充按鍵列</string>
    <string name="back_opens_hint">開啟時，在擴充按鍵列隱藏狀態下按返回鍵會顯示它，再次按返回鍵則隱藏。</string>
    <string name="keyboard_floating_switch">鍵盤懸浮（覆蓋顯示區域）</string>
    <string name="keyboard_floating_hint">開啟時，軟鍵盤和擴充按鍵列會懸浮在顯示區域之上，而不是縮小顯示區域；按鍵列使用半透明背景並隨鍵盤升起，但顯示區域不會被調整大小。關閉時保持原有行為（顯示區域縮小以騰出空間）。下次返回桌面時生效。</string>

    <!-- Custom layout editor -->
    <string name="btn_load_default">載入預設範本</string>
    <string name="btn_load_file">從檔案載入…</string>
    <string name="layout_hint">以 JSON 定義擴充按鍵列：\"rows\" 是列的陣列，每列又是按鍵的陣列。每個按鍵都有 \"label\" 和 \"type\"（key/text/modifier/keyboard/vkeyboard/settings）。\"key\"/\"modifier\" 需要 evdev 的 \"code\"；\"text\" 需要 \"text\"；任意按鍵可加入 \"repeat\":true 或巢狀的 \"popup\"。無效的 JSON 會回退到預設配置。下次返回桌面時生效。</string>
    <string name="layout_status_default">正在使用內建預設配置</string>
    <string name="layout_status_valid">✓ 配置有效</string>
    <string name="layout_status_invalid">✗ %1$s</string>

    <!-- Touchpad -->
    <string name="touchpad_mode_switch">觸控板模式（相對移動）</string>
    <string name="touchpad_hint">開啟：手指滑動移動滑鼠游標（相對）。關閉：觸控直接對應到螢幕（絕對）。</string>
    <string name="mouse_sensitivity_label">滑鼠靈敏度（加速度）</string>
    <string name="mouse_accel_value">%1$.1f 倍</string>

    <!-- Connection -->
    <string name="socket_path_label">守護程序 socket 路徑</string>
    <string name="second_window_label">開啟第二個視窗（獨立守護程序與標題）</string>
    <string name="second_window_name_hint">視窗名稱（如 work）</string>
    <string name="second_window_open">開啟第二個視窗</string>
    <string name="root_switch">使用 root 連線（輔助程式）</string>
    <string name="root_hint">啟動一個 root 輔助程式（su）連線到 socket，並將連線傳回應用程式。下次連線時生效（請重新開啟應用程式）。</string>
    <string name="mic_switch">將麥克風轉發到桌面</string>
    <string name="mic_hint">桌面音訊始終透過本裝置的喇叭播放。啟用此項還會把麥克風反向發送到桌面。下次連線時生效（請重新開啟應用程式）。</string>
    <string name="camera_switch">將相機轉發到桌面</string>
    <string name="camera_hint">允許桌面將本裝置的相機作為視訊來源開啟。僅在桌面正在錄製時相機才會開啟。下次返回應用程式時生效；首次使用會請求相機權限。</string>
    <string name="audio_latency_title">音訊延遲</string>
    <string name="latency_speaker_label">喇叭（桌面 → 手機）</string>
    <string name="latency_mic_label">麥克風（手機 → 桌面）</string>
    <string name="latency_hint">較低的預設可降低延遲，但在裝置繁忙時可能造成雜音/掉格。返回桌面檢視時生效。</string>

    <!-- Resolution -->
    <string name="width_hint">寬度（例如 1920）</string>
    <string name="height_hint">高度（例如 1080）</string>
    <string name="resolution_hint">選擇預設或手動輸入數值。填 0 表示原生解析度。\"Screen ×\" 會依本裝置面板（橫向）縮放。下次連線時生效。</string>

    <!-- Settings notification -->
    <string name="notification_switch">顯示設定通知</string>
    <string name="notification_hint">應用程式開啟時顯示一則常駐通知，點按可直接進入設定。關閉後不再顯示。下次返回應用程式時生效。</string>
